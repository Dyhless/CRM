# Option 1: MockAPI project token (preferred for this project)
# Example: if your base URL is https://abc123.mockapi.io/api/v1 then token is abc123
NEXT_PUBLIC_PROJECT_TOKEN=

# Option 2: Full API base URL (used when PROJECT_TOKEN is not set)
# Example: https://abc123.mockapi.io/api/v1
NEXT_PUBLIC_API_BASE_URL=
